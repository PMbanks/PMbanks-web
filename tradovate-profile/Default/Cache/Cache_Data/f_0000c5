ue of the Hull avg, on the 5, it will either bounce off or make a violent jump across, indicating that this value is being considered. Good luck\n\nemail: rnscttmtthws at gmail.com  \nI've found this to be invaluable and I'd sure like to hear from someone else if they, too, found this useful","updated":"2024-10-17T15:37:20.988Z","allowDirectLink":true,"hidden":false,"entityType":"workspace","id":"a3d654be-936b-44ab-98a2-eb2866082115","authorId":2661357,"likes":0,"usageScore":0,"shares":204,"trendingScore":2,"sources":{"Micro scalping 2, 12 sec - cracking the code":{"name":"Micro scalping 2, 12 sec - cracking the code.workspace.tradovate"}},"images":["38d03129-bdcd-4a3f-b7d6-eb7bf2b42152","42b8fc0d-f2af-4b19-ba68-d4e9f2cfa4f9","47b51119-a839-42d1-afa5-7e66910490e9"],"author":"aaron matthews"},{"caption":"RWC","text":"Risk Reward Calculator","updated":"2026-03-13T18:48:08.035Z","link":"","allowDirectLink":true,"hidden":false,"id":"7b2a51cf-96b6-4b35-bb89-f5ea64029b4f","entityType":"chartIndicator","obfuscated":false,"entitlement":false,"indicators":["Auto contract sizing risk reward calculator"],"authorId":5409160,"likes":0,"trendingScore":31,"usageScore":16,"shares":204,"sources":{"RiskRewardCalculator.js":{"name":"RiskRewardCalculator.js"}},"images":[],"author":"Eduardo Martinez"},{"caption":"TO - TraderSmarts","text":"TraderSmarts lines located at TraderSmarts.net.","link":"","allowDirectLink":true,"hidden":false,"id":"a7728ad0-9d16-41ed-aac8-db9276ea38de","entityType":"chartIndicator","obfuscated":false,"entitlement":false,"indicators":["TO - TraderSmarts"],"authorId":657976,"likes":0,"updated":"2025-03-09T14:44:32.683Z","shares":204,"trendingScore":2,"usageScore":22,"sources":{"TraderSmarts.js":{"name":"TraderSmarts.js"}},"images":[],"author":"TraderOracle"},{"caption":"VWAPandDevx4","text":"VWAPandDevx4","updated":"2025-08-20T07:56:40.026Z","link":"","allowDirectLink":true,"hidden":false,"id":"065ca334-6c16-4861-bc92-2dba9a6dc8db","entityType":"chartIndicator","