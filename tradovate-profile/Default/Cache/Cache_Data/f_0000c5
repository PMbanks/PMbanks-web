tantly, but the label only fires when the higher timeframe agrees. This stops you from fighting the larger trend.\n3. Volume confirmation\nThe flip bar must show elevated volume — above the 20-bar average by a user-defined threshold. A supertrend flip on thin volume is often a fake-out. This gate filters t","updated":"2026-03-24T20:55:17.022Z","link":"","allowDirectLink":true,"hidden":false,"id":"6ccb4941-5777-4c7b-ab9f-95763c872fd3","entityType":"chartIndicator","obfuscated":false,"entitlement":false,"indicators":["Smooths Trend Breaker"],"authorId":6886127,"likes":0,"shares":39,"trendingScore":4,"usageScore":33,"sources":{"SmoothsTrendBreakerTradovate.js":{"name":"SmoothsTrendBreakerTradovate.js"}},"images":[],"author":"CaptainSmooth"},{"caption":"test1","text":"avwap test","updated":"2025-11-19T16:14:28.185Z","link":"","allowDirectLink":false,"id":"04a1688e-06c2-4cfd-bc3e-87e71583bef5","entityType":"chartIndicator","obfuscated":false,"entitlement":false,"indicators":["Auto-anchors AVWAP to rolling RTH High/Low, resets daily"],"authorId":4414352,"likes":0,"hidden":false,"shares":39,"trendingScore":3,"usageScore":5,"sources":{"AutoHoDLoDAVWAP_FIXED_FINAL.js":{"name":"AutoHoDLoDAVWAP_FIXED_FINAL.js"}},"images":[],"author":"Splug"},{"caption":"ADx di AREA","text":"shows the total area of di plus and minus","updated":"2025-07-09T15:26:50.294Z","link":"","allowDirectLink":true,"hidden":false,"id":"6ef8df07-e5a3-4ac3-9bb4-9c77adc4bd44","entityType":"chartIndicator","obfuscated":false,"entitlement":false,"indicators":["Average directional index with spread"],"authorId":5049011,"likes":0,"shares":38,"trendingScore":1,"usageScore":0,"sources":{"spreadtest.js":{"name":"spreadtest.js"}},"images":[],"author":"julian gonzalez"},{"caption":"ElWeR","text":"williams r + ema","updated":"2024-11-12T15:45:09.503Z","link":"","allowDirectLink":true,"hidden":false,"id":"44bd18db-186a-43cc-820c-f0b516b519c3","entityType":"chartIndicator","obfuscated":false,"entitlement":false,"indicator