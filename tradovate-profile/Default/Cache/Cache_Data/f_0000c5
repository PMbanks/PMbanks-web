as mediante colores.\nParámetros configurables:\n\nSensibilidad: Ajusta la distancia de los niveles de soporte/resistencia (mayor sensibilidad para mercados más volátiles).\nLongitud del ATR: Controla la suavidad del cálculo del ATR.\nLongitud de la nube: Ajusta la duración de las medias móviles.","updated":"2024-11-19T01:52:52.657Z","link":"","allowDirectLink":true,"hidden":false,"id":"27ea9114-b8e1-42e2-8f8b-c09e7f87b5d4","entityType":"chartIndicator","obfuscated":false,"entitlement":false,"indicators":["SMA"],"authorId":3621097,"likes":0,"shares":341,"trendingScore":5,"usageScore":1,"sources":{"Charo.js":{"name":"Charo.js"}},"images":[],"author":"Sotomonte"},{"hidden":false,"entityType":"workspace","caption":"SpyGuyTwitMain","indicators":[],"authorId":347345,"usageScore":0,"allowDirectLink":true,"id":"f3817315-18cf-4d39-937c-c069b100bc29","text":"Used modules: Performance Center, Quote Board, Chart\nUsed indicators: p2f - Lonesome Cumulative Delta, Volume Profiles, ATR TrailStop w/Fib Targets, p2f - Hurst Bands\nTheme: dark","updated":"2022-03-31T15:28:33.312Z","likes":0,"trendingScore":1,"shares":340,"sources":{"SpyGuyTwitMain":{"name":"SpyGuyTwitMain.workspace.tradovate"}},"images":["419608e5-77e0-461f-bfb9-cd7f0540b843"],"author":"spyguytrading"},{"caption":"Supply and demand 4","text":"Uses 3 candle engulfing to mark out previous bearish or bullish candles.","updated":"2026-01-25T02:48:23.951Z","link":"","allowDirectLink":true,"hidden":false,"id":"9d506e5f-5add-4ed5-a2b2-0511e802001b","entityType":"chartIndicator","obfuscated":false,"entitlement":false,"indicators":["Verified 3-Candle Wick Zones"],"authorId":6420537,"likes":0,"shares":340,"trendingScore":25,"usageScore":89,"sources":{"supplydemand4.js":{"name":"supplydemand4.js"}},"images":[],"author":"Lancelot"},{"caption":"EMA Slope Alignment (EMA9 & EMA 14)","text":"Displays and measures the slop (angle/strength) of EMA9 and EMA14 in real time to identify trend alignment and momentum phases.\n\nThis custom indicator plots the slope of EMA9 and EMA14 as a dynamic, real-time value that helps traders visualize trend strength and direction.\n\n-When both slopes are aligned and increasing → strong momentum trend.\n-When slopes diverge or flatten → potential exhaustion or reversal zone.\n\nTweaks:\n-You can change which EMAs to compare by modifying the emaPeriods array.\n-You can adjust smoothing length (slopeSmoothPeriod) to make slope lines more or less responsive.\n-Colors and line widths can be changed in the schemeStyles section.","updated":"2025-10-11T02:09:24.527Z","link":"","allowDirectLink":true,"hidden":false,"id":"55b23c03-1ee4-425e-9138-81b0c68cae3b","entityType":"chartIndicator","obfuscated":false,"entitlement":false,"indicators":["SMA"],"authorId":5572572,"likes":0,"shares":338,"trendingScore":22,"usageScore":18,"sources":{"EMASlopeAlignment.js":{"name":"EMASlopeAlignment.js"}},"images":[],"author":"Murph"},{"caption":"Delta Bubbles","text":"This is a debugged version of Sethmo's Large Delta Bubbles. Fixed GBX and sma","updated":"2026-03-16T03:19:27.069Z","link":"","allowDirectLink":true,"hidden":false,"id":"b847b2f5-0fc7-40b1-bd92-2f51039dbc1b","entityType":"chartIndicator","obfuscated":false,"entitlement":false,"indicators":["Delta Bubbles"],"authorId":4815481,"likes":0,"shares":337,"trendingScore":53,"usageScore":352,"sources":{"DeltaBubbles.js":{"name":"DeltaBubbles.js"}},"images":[],"author":"ROCASCEMTE"},{"caption":"WAE Candles","text":"Waddah Attar Explosion indicator that colours candles only during explosion events.","updated":"2025-03-09T07:18:41.435Z","link":"","allowDirectLink":true,"hidden":false,"id":"985bfe0c-978a-4f5e-b0a8-32277e05ddc1","entityType":"chartIndicator","obfuscated":false,"entitlement":false,"indicators":["WAE Coloured Candles"],"authorId":2584109,"likes":0,"usageScore":76,"shares":334,"trendingScore":6,"sources":{"WAECandles.js":{"name":"WAECandles.js"}},"images":["d93bf29f-6c80-4d9c-bcd7-38bb5bdfb879"],"author":"James I"},{"capt