obfuscated":false,"entitlement":false,"indicators":["SMA"],"authorId":2886330,"likes":0,"shares":831,"trendingScore":25,"usageScore":38,"sources":{"PO3.js":{"name":"PO3.js"},"PO3shii.js":{"name":"PO3shii.js"}},"images":[],"author":"undawater"},{"caption":"TraderOracle Buy Sell Dots with Alerts","text":"TraderOracle Buy Sell Dots with Alerts","updated":"2025-03-28T15:21:16.491Z","link":"","allowDirectLink":true,"hidden":false,"id":"0d706a51-ff7e-4454-820a-796fe126c926","entityType":"chartIndicator","obfuscated":false,"entitlement":false,"indicators":["Buy/Sell Dots with Audio Alerts"],"authorId":4225772,"likes":0,"shares":826,"trendingScore":29,"usageScore":149,"sources":{"OracleBuySellDotsalerts.js":{"name":"OracleBuySellDotsalerts.js"}},"images":[],"author":"Trader Da"},{"hidden":false,"entityType":"chartIndicator","link":"","caption":"Detrended Price & Delta with Candle Color","entitlement":false,"indicators":["Detrended Price & Cumulative Delta"],"authorId":553965,"allowDirectLink":true,"text":"This is an oscillator with detrended price and cumulative delta so they can be viewed in the same oscillator at the same scale. \n\nThere is an option to color the candles based on if both the detrended price and detrended delta are on the same side of the zero line at the same time. If both aren't then the candles are gray. There are also options to only color the candles based on only detrended price or only detrended delta.\n\nThere is an option to color the line plots with the momentum of each line which can be controlled with the Signal Line Length.\n\nFrom some testing it appears that the detrended lines can be used to look for divergences very similar to a MACD.\n\nThe first smoothing setting for each is smoothing price before it gets detrended. The second (post) smoothing option is directly smoothing the line on the oscillator after it has been detrended. \n\nI can't fit more tips here due to the maximum character limit but feel free to reach me at @TheTradeEngine on twitter if you have any questions.","id":"14e08499-0c9e-4f9b-ad3f-48095235af01","updated":"2024-09-07T22:03:58.361Z","obfuscated":false,"likes":0,"shares":817,"trendingScore":0,"usageScore":167,"sources":{"DetrendedPriceAndDelta.js":{"name":"DetrendedPriceAndDelta.js"}},"images":["48959415-785a-41ae-a6da-b1151ccaf9b3"],"author":"tommytrades"},{"caption":"FVG","text":"Fair Value Gap","updated":"2025-12-12T22:07:13.677Z","link":"","allowDirectLink":true,"hidden":false,"id":"6c6f31ee-942e-46ad-aca3-126eb894459d","entityType":"chartIndicator","obfuscated":false,"entitlement":false,"indicators":["FVG"],"authorId":5873709,"likes":0,"shares":815,"trendingScore":56,"usageScore":57,"sources":{"FvgZones.js":{"name":"FvgZones.js"}},"images":[],"author":"Alligator Al"},{"entityType":"template","module":"funCharts","caption":"MES_GOAT_Final_Chapter","indicators":[],"authorId":216567,"usageScore":0,"allowDirectLink":false,"text":"Used indicators: tystr - Improved Tiki Trend, MACD SMA, Keltner Channels","id":"11627d95-f8d1-4fd1-9a00-66de62c57607","updated":"2021-04-01T04:53:35.188Z","likes":0,"hidden":false,"shares":808,"trendingScore":1,"sources":{"MES_GOAT_Final_Chapter":{"name":"MES_GOAT_Final_Chapter.template.tradovate"}},"images":[],"author":"jnitro"},{"caption":"SVP Session Volume Profile","text":"AD_2\nThe images shown are a few from my discord server's SVP forum which I also posted in the tradovate forum which is linked below. This is a revamped ad since the first one is now greatly outdated due to the various updates that have been made to the indicator.\nAlthough most of my indicators are free this one is paid access. I will never overprice a tradovate indicator so just know it is below $5.01. My discord server is linked on my tradovate forum profile and in this script's code editor if you are interested.","link":"https://community.tradovate.com/t/svp-session-volume-profile/12572?u=unlimitidities","allowDirectLink":true,"hidden":false,"id":"d7425d14-d6ac-452e-b129-58436eb710e9","entityType":"chartIndicator","obfuscated":false,"entitlement":false,"indicators":["SVP Banner"],"authorId":5094514,"likes":0,"updated":"2026-04-26T22:59:01.492Z","shares":795,"trendingScore":95,"usageScore":85,"sources":{"SVP_ad.js":{"name":"SVP_ad.js"}},"images":["00f3f50d-0143-4f07-bf3c-261470da79be","4986d58b-e263-4372-8524-bc7ea85d9b64","9ea0f59a-c4c5-4549-a626-3d180469359a"],"author":"Unlimitidities"},{"hidden":false,"entityType":"chartIndicator","link":"","caption":"ATR with no Display","entitlement":false,"indicators":["Average True Range (ATR)"],"authorId":2638059,"allowDirectLink":true,"text":"This gets rid of the graph histogram and simply displays the ATR per candle in the data box.","id":"9d86f12d-b5bd-4d9b-9d63-9809f1a07139","obfuscated":false,"likes":0,"updated":"2024-06-11T16:59:18.276Z","trendingScore":7,"shares":775,"usageScore":99,"sources":{"ATR.js":{"name":"ATR.js"}},"images":[],"author":"Swift"},{"hidden":false,"entityType":"chartIndicator","link":"","caption":"Latter-day Trader: 310 Oscillator","indicators":["LDT - 310 Oscillator"],"authorId":207522,"allowDirectLink":true,"id":"d76362c1-70f3-479e-988d-01938ed3978c","text":"The ThreeTen oscillator by Linda Raschke. This defaults to showing only the slow or smooth line. You have the option to enable both the fast line and the histogram.\n\nFor the histogram, it defaults to using the difference of the the fast and smooth line, which is how the MACD does it. Or, you can use the fast line itself as the histogram, which is how other 310 oscillator implementations do it.","obfuscated":false,"likes":0,"updated":"2021-06-02T21:46:44.712Z","shares":770,"trendingScore":3,"usageScore":22,"sources":{"LDT_310_Oscillator.js":{"name":"LDT_310_Oscillator.js"}},"images":[],"author":"LatterDayTrader"},{"hidden":false,"entityType":"chartIndicator","link":"","caption":"Adaptive Donchian Channel [Trendoscope]","entitlement":false,"indicators":["Adaptive Donchian Channel"],"authorId":1562880,"allowDirectLink":true,"text":"Donchian Channel is a simple indicator which plots highest and lowest of last N bars.  Uses of donchian channel are mainly to find breakouts from the long term range. The problem with traditional donchian channel indicator is that the channels contract during the contraction period and hence will not highlight the breakouts efficiently or does a premature highlighting of breakouts.\n\nIn order to overcome this problem, we have coined this new concept of Adaptive Donchian Channel. The logic of calculation of channels remain almost same. The only differentiating factor is that the channels update only when price has breached the previous values of the channels.\n\nThis will help retain the channel width during contraction period in order to filter fakeouts from breakouts.","id":"73738464-6912-495e-a634-dc5f417f0f83","updated":"2023-10-09T11:23:02.513Z","obfuscated":false,"likes":0,"trendingScore":5,"shares":765,"usageScore":46,"sources":{"adaptiveDC.js":{"name":"adaptiveDC.js"}},"images":[],"author":"Trendoscope"},{"caption":"Daily Mobile Levels Indicator 1","text":"This Daily Mobile Levels Indicator is designed to track and display key market levels, providing traders with essential support and resistance data. It identifies significant price points such as:\n\nSupport Levels (S1-S4): Representing potential buy zones, these levels are highlighted in yellow.\nResistance Levels (R1-R4): Acting as possible sell zones, these are marked in red.\nSupply & Demand Zones: The supply zone is colored pink, indicating a potential sell area, while the demand zone is purple, signaling potential buying strength.\nValue Area High (VAH) & Low (VAL): These blue and green levels respectively help traders identify key price areas where the market has previously balanced.\nPoint of Control (POC): Displayed in deep pink, marking the most traded price level for the session.\nPrevious Day High, Low, & Close: These key reference points are used to gauge potential price movement.\nPrevious Week High & Low: Providing insights into broader market trends and possible breakout zones.\nMidnight Level: ICT","updated":"2025-02-16T22:03:53.219Z","link":"","allowDirectLink":true,"hidden":false,"id":"47ce3407-5bf8-45d1-a1c2-2770810c4a4e","entityType":"chartIndicator","obfuscated":false,"entitlement":false,"indicators":["Tracks and displays key session levels including support, resistance, supply, demand, VAH, VAL, and more."],"authorId":2219171,"likes":0,"trendingScore":13,"shares":762,"usageScore":54,"sources":{"dailylevelsmobileapp.js":{"name":"dailylevelsmobileapp.js"}},"images":[],"author":"servantthought"},{"hidden":false,"entityType":"chartIndicator","caption":"Golden Fib with % Hidden","entitlement":false,"indicators":["+ Golden Fibonacci Retracement"],"authorId":381323,"usageScore":0,"allowDirectLink":true,"text":"Golden Fib with % Hidden","id":"a0c230e1-6e76-43ed-9822-b2b27621f083","updated":"2024-03-04T01:25:34.820Z","obfuscated":false,"likes":0,"shares":760,"trendingScore":5,"sources":{"Sethmo Golden Fibonacci Retracement Tool_sethmoFibRetracement.js":{"name":"Sethmo Golden Fibonacci Retracement Tool_sethmoFibRetracement.js"}},"images":[],"author":"nakamotorboat"},{"hidden":false,"entityType":"chartIndicator","link":"","caption":"Bollinger Band Touch","indicators":["BollingerBandTouch"],"authorId":211399,"allowDirectLink":true,"text":"Candle is colored when high or low touches bollinger bands","id":"9e98efab-e291-4dc5-a26c-b7cf4371dd8c","obfuscated":false,"likes":0,"updated":"2021-08-23T13:55:24.370Z","shares":758,"trendingScore":-1,"usageScore":67,"sources":{"BollinngerBandTouch.js":{"name":"BollinngerBandTouch.js"}},"images":[],"author":"el dedo"},{"hidden":false,"entityType":"chartIndicator","link":"","caption":"Bulls to Bears Ratio per Candle","entitlement":false,"indicators":["Bulls to Bears Ratio"],"authorId":2638059,"allowDirectLink":true,"text":"The \"Bulls to Bears Ratio per Candle\" indicator calculates and displays the rati