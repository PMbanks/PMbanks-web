ence.js":{"name":"LooseDeltaDivergence.js"}},"images":[],"author":"Chance Lambert"},{"caption":"RSIKH","authorId":66261,"indicators":["Relative Strength Index"],"text":"NIVELES 80-20","id":"5ca6650dee7a2e5c0123e3b9","updated":"2019-04-04T20:12:20.506Z","likes":0,"trendingScore":0,"usageScore":31,"shares":702,"sources":{"RSIKH":{"name":"RSIKH.js"}},"images":[],"author":"RSIPERSONAL"},{"caption":"(ADR) Average Daily Range Pivot levels.","text":"This is an intraday indicator.\n\nAverage Daily Range provides an upper and lower level around the daily open. It is calculated by taking an EMA/SMA average Plots the ADR levels from the open of a session. You can select the increments but you will have to input the average daily range. \nAdvantages of this Indicator\n• This is a Leading indicator, not Dynamic or Repaint.\n•Highly beneficial for Day Traders \nHelps to identify the reversal points.\n• Can practically follow the Buy Low and Sell High principle.\n• Helps to keep minimum Stop Loss.\nEntry\n• Long entry when the Price reach at or closer to the Green 50% level.\n• Long entry when the Price retraces to the green support lines. .\n• Short entry when the Price reach at or closer to the Red 50% level.\n• Short entry when the Price retrace to the red resistance lines. \n\nExit\n• Use ADR levels as targets.\n• Or use the Target levels in the indicator for breakouts.\n• Use the 50% and 100% levels as target.\n• Use Support or Resistance lines as targets in reversal method.","updated":"2025-06-08T15:24:31.858Z","link":"","allowDirectLink":true,"hidden":false,"id":"b4e8de32-7852-4371-a6df-c52e77b44bbd","entityType":"chartIndicator","obfuscated":false,"entitlement":false,"indicators":["ADR Pivots"],"authorId":3015936,"likes":0,"shares":694,"trendingScore":16,"usageScore":33,"sources":{"ADRPivots.js":{"name":"ADRPivots.js"}},"images":["b7dfc4bc-b971-4d95-a34a-4ad45f73ba23"],"author":"OverTrader"},{"caption":"StormScalp MTM","text":"super agressive trading bot\n ✅ Custom Indicator & Drawing Tool\n✅ Volatility Filter & Market Trend Strategies\n✅ Tight Risk Management with Adjustable Parameters\n✅ Buy & Sell with Stop Loss & Trailing Stops\n✅ Aggressive Scalping Trades (80% Win Rate Goal)","updated":"2025-02-22T21:27:45.000Z","link":"","allowDirectLink":false,"id":"e824db92-71ac-4994-a2c8-0761c0656b6e","entityType":"chartIndicator","obfuscated":false,"entitlement":false,"indicators":["SMA"],"authorId":4311093,"likes":0,"hidden":false,"shares":692,"trendingScore":9,"usageScore":5,"sources":{"StormScalpMTM.js":{"name":"StormScalpMTM.js"}},"images":[],"author":"Josh"},{"hidden":false,"entityType":"chartIndicator","link":"","caption":"Williams Alligator","authorId":187183,"indicators":["Alligator"],"allowDirectLink":true,"id":"e03ce998-a0fc-48f6-9f96-2e9b5268aee3","text":"This indicator is straight from Tradovate's indicator tutorial page - nothing modified other than the source link addition. Posting it here for others convenience.","updated":"2021-06-18T21:45:41.820Z","obfuscated":false,"likes":0,"trendingScore":1,"shares":692,"usageScore":14,"sources":{"Alligator_Tradovate.js":{"name":"Alligator_Tradovate.js"}},"images":[],"author":"bnotb"},{"caption":"ICT SMT","text":"ICT 📊","updated":"2025-10-13T19:58:51.747Z","allowDirectLink":true,"hidden":false,"entityType":"template","module":"funCharts","indicators":[],"id":"827bab5f-e93e-489f-b662-e73e1405a834","authorId":824709,"likes":0,"usageScore":0,"shares":690,"trendingScore":35,"sources":{"ICT SMT":{"name":"ICT SMT.template.tradovate"}},"images":[],"author":"SrVicini "},{"caption":"Fisher Transform","authorId":17473,"indicators":["STO"],"id":"9795d115-be07-42f1-8f65-8bfe91fca2de","text":"fisher transform","updated":"2020-06-03T16:18:16.619Z","likes":0,"shares":689,"trendingScore":2,"usageScore":40,"sources":{"fisher":{"name":"fisher.js"}},"images":[],"author":"AA FT"},{"hidden":false,"entityType":"template","module":"funCharts","caption":"MagnaCloud Template","indicators":[],"authorId":187183,"