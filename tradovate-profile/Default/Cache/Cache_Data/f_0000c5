":false,"entityType":"chartIndicator","link":"","caption":"Tiki SSL","entitlement":false,"indicators":["Tiki SSL"],"authorId":1103,"allowDirectLink":true,"id":"7d51a9a5-9fe3-44c8-b4d0-d8e22185a813","text":"Known as the SSL, the Semaphore Signal Level channel chart alert is an indicator that combines moving averages to provide you with a clear visual signal of price movement dynamics. In short, it's designed to show you when a price trend is forming.","obfuscated":false,"likes":0,"updated":"2024-11-06T15:57:46.428Z","shares":1193,"trendingScore":5,"usageScore":152,"sources":{"tikiSSL.js":{"name":"tikiSSL.js"}},"images":[],"author":"Tiki Dave"},{"hidden":false,"entityType":"chartIndicator","link":"","caption":"Plot horizontal lines","entitlement":false,"authorId":16592,"indicators":["Manual Horizontal Lines"],"allowDirectLink":true,"id":"a766e21b-faaa-4441-89f5-640e8b489cea","text":"An alternative to using the horizontal drawing tool.","obfuscated":false,"likes":0,"updated":"2022-02-16T15:55:20.596Z","shares":1178,"trendingScore":3,"usageScore":128,"sources":{"HorizontalLines.js":{"name":"HorizontalLines.js"}},"images":[],"author":"Bas"},{"caption":"Automatic Trend Line Detection","text":"Automatically detects and draws uptrend and downtrend lines by connecting swing highs and lows.  Highlights the most recent trend lines and optionally displays a short history of previous trends.  Designed for clarity and minimal chart clutter, with support for all major asset classes.\n\nFeatures:\n- Detects swing highs and lows using a configurable \"strength\" parameter.\n- Draws the most recent uptrend and downtrend lines, extending them to the right edge of the chart.\n- Optionally displays a short history of previous trend lines for context.\n- Automatically adapts to instrument tick size (works for futures, forex, etc).\n- Customizable line colors, width, and opacity.\n- Minimal memory usage and efficient for real-time and historical charts.\n\nUsage:\n- Add the indicator to your chart.\n- Adjust the \"strength\" parameter to control swing sensitivity (higher = fewer, more significant swings).","updated":"2025-06-30T02:30:32.445Z","link":"","allowDirectLink":true,"hidden":false,"id":"342fb951-c86b-475f-9956-4d551aca6254","entityType":"chartIndicator","obfuscated":false,"entitlement":false,"indicators":["Automatic Trend Line Detection"],"authorId":155358,"likes":0,"shares":1174,"trendingScore":37,"usageScore":532,"sources":{"autoTrend.js":{"name":"autoTrend.js"}},"images":[],"author":"Vamp"},{"hidden":false,"entityType":"template","module":"funCharts","caption":"ES Delta FootPrint Emanuel Giovanelli","indicators":[],"authorId":1398406,"usageScore":0,"allowDirectLink":true,"text":"Used indicators: Sethmo Price Axis Volume Delta, Variable Resolution Delta, Sethmo Volume Delta Grid Clean, Sethmo Large Delta Bubbles","id":"17edda60-d0ab-4736-a543-6acbd929100a","updated":"2024-04-26T20:23:45.273Z","likes":0,"shares":1167,"trendingScore":12,"sources":{"ES Delta FootPrint Emanuel Giovanelli":{"name":"ES Delta FootPrint Emanuel Giovanelli.template.tradovate"}},"images":["ce9f06bd-e40d-4310-9180-e0b513a01104"],"author":"Ema Giovanelli"},{"caption":"Asia/London/NY Highs and Lows","text":"Asia/London/NY Highs and Lows","updated":"2026-01-29T14:44:42.278Z","link":"","allowDirectLink":true,"hidden":false,"id":"aa2b6de3-ca2e-40d6-8987-a42e554ace3a","entityType":"chartIndicator","obfuscated":false,"entitlement":false,"indicators":["Session Highs and Lows"],"authorId":5825275,"likes":0,"shares":1162,"trendingScore":68,"usageScore":422,"sources":{"ScottsTools":{"name":"ScottsTools"},"SessionHighsNLows.js":{"name":"SessionHighsNLows.js"}},"images":[],"author":"ScottsORB"},{"caption":"High Accuracy Scalper","text":"this is a high accuracy scalping indicator that tells you when to buy and sale when trading micro e mini dow 0.50 this bit has stop loss and take profit filters added it follows the market trends to ensure accuracy in you trades","updated":"2025-