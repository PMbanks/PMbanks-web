ad Simple Reversal, Camarilla Pivot Points, NOM VWAP Bands, LDT - Moving Average Bands, Tiki OHLC, Tiki Squeeze, Hull Moving Average, Bollinger Bands, Relative Strength Index\nTheme: dark","id":"2fd9d8cb-cb11-4c41-b4f3-542f242ed969","updated":"2022-09-15T15:52:15.905Z","likes":0,"shares":92,"trendingScore":0,"sources":{"H O M E  S C R E E N":{"name":"H O M E  S C R E E N.workspace.tradovate"}},"images":[],"author":"COYOTE BONGWATER"},{"caption":"Price Position","text":"This indicator calculates and displays the price position within a rolling window of historical prices. The price position indicates where the current price sits within the high-low range, providing a measure of relative price position (0.0 = bottom of range, 1.0 = top of range, 0.5 = middle).\n\nFeatures:\n - Calculates price position using a configurable rolling window period (default: 10 bars).\n - Provides smoothed price position using a configurable smoothing period (default: 5 bars).\n - Displays horizontal reference lines at 0.0 (bottom), 0.5 (middle), and 1.0 (top) for easy interpretation.\n - Color-coded reference lines for visual clarity.\n - Customizable colors and line widths for reference lines.\n - Displays in a separate panel with proper 0-1 scaling.\n - Robust error handling and performance optimization with automatic data cleanup.","updated":"2025-11-16T03:59:37.815Z","link":"","allowDirectLink":true,"hidden":false,"id":"003976ec-30c9-41e1-a099-86000ff6845c","entityType":"chartIndicator","obfuscated":false,"entitlement":false,"indicators":["Price Position"],"authorId":155358,"likes":0,"usageScore":2,"shares":92,"trendingScore":6,"sources":{"pricePosition.js":{"name":"pricePosition.js"}},"images":[],"author":"Vamp"},{"hidden":false,"entityType":"workspace","caption":"TPO/Szymon dobre","indicators":[],"authorId":479969,"usageScore":0,"allowDirectLink":true,"text":"Used modules: DOM, Tick Stream, Chart\nUsed indicators: Volume Delta Grid, NOM VWAP Bands, Cumulative Delta, Tiki VWAP\nThem